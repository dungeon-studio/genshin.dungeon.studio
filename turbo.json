{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env*", "pnpm-lock.yaml", "pnpm-workspace.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "package.json",
        "vite.config.*",
        "index.html",
        "tsconfig*.json"
      ],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["**/*.{ts,tsx}", "package.json", "eslint.config.*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "vite.config.*", "vitest.config.*", "tsconfig*.json"],
      "env": ["FAST_CHECK_SEED"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**/*.{ts,tsx}", "package.json", "vite.config.*", "tsconfig*.json"]
    },
    "schemas:export": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/repositories/*/schemas/**",
        "scripts/export-schemas.ts",
        "scripts/schema-registry.ts"
      ],
      "outputs": ["schema-snapshots/**"]
    },
    "schemas:check": {
      "dependsOn": ["^build"],
      "passThroughEnv": ["SCHEMA_COMPAT_BASE"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
