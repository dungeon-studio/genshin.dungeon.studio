    // ============================================
    // Build Tasks
    // ============================================
    {
      "label": "build: all",
      "type": "shell",
      "command": "pnpm build",
      "problemMatcher": ["$tsc", "$eslint-stylish"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "build: web",
      "type": "shell",
      "command": "pnpm --filter @genshin/web build",
      "problemMatcher": ["$tsc"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },

    // ============================================
    // Testing Tasks (Ready for Vitest)
    // ============================================
    {
      "label": "test: all",
      "type": "shell",
      "command": "pnpm test",
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "test: watch",
      "type": "shell",
      "command": "pnpm test -- --watch",
      "isBackground": true,
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "test: web",
      "type": "shell",
      "command": "pnpm --filter @genshin/web test",
      "problemMatcher": [],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
