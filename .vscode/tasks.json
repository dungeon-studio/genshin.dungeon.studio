    // ============================================
    // Linting & Formatting
    // ============================================
    {
      "label": "lint: all",
      "type": "shell",
      "command": "pnpm lint",
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "lint: web",
      "type": "shell",
      "command": "pnpm --filter @genshin/web lint",
      "problemMatcher": ["$eslint-stylish"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "format: all",
      "type": "shell",
      "command": "pnpm format",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },

    // ============================================
    // Cleanup Tasks
    // ============================================
    {
      "label": "clean: all",
      "type": "shell",
      "command": "pnpm clean",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },

    // ============================================
    // Package Management
    // ============================================
    {
      "label": "install: dependencies",
      "type": "shell",
      "command": "pnpm install",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }

