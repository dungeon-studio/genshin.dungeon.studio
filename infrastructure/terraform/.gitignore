# Terraform state and plan files
*.tfstate
*.tfstate.*
.terraform/

# Crash log files
crash.log
crash.*.log

# Exclude sensitive tfvars files only; terraform.tfvars is committed for non-sensitive values
*.secrets.tfvars
*.secrets.tfvars.json
terraform.local.tfvars
terraform.local.tfvars.json
!example.tfvars

# Local value overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include an example override file so contributors can see the pattern,
# even though real local override files are ignored above.
!example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
*tfplan*

# IDE
.idea/
.vscode/
*.swp
*.swo
