{
  // SPDX-FileCopyrightText: 2026 Alex Brandt <alunduil@gmail.com>
  // SPDX-License-Identifier: MIT
  "name": "Genshin Planner",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:2": {
      "version": "24.18.0"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/terraform:1": {},
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/shinepukur/devcontainer-features/vale:1": {
      "version": "3.14.1"
    },
    "ghcr.io/devcontainers-extra/features/firebase-cli:2": {},
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "installGradle": false,
      "installMaven": false
    }
  },

  "customizations": {
    "vscode": {
      // MAINTENANCE: Keep this list in sync with .vscode/extensions.json
      "extensions": [
        // Language support
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // TypeScript enhancements
        "yoavbls.pretty-ts-errors",

        // Documentation
        "chrischinchilla.vale-vscode",

        // Developer experience
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",
        "meganrogge.template-string-converter",

        // Styling
        "bradlc.vscode-tailwindcss",

        // Containerization
        "ms-azuretools.vscode-docker",

        // Infrastructure as Code
        "hashicorp.terraform",

        // Testing (when Vitest is fully configured)
        "vitest.explorer",

        // API testing
        "rangav.vscode-thunder-client"
      ]
    }
  },

  "forwardPorts": [5173, 8080, 9099],
  "portsAttributes": {
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Backend (Hono)",
      "onAutoForward": "notify"
    },
    "9099": {
      "label": "Firebase Auth Emulator",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "bash .devcontainer/postCreateCommand.sh",
  "updateContentCommand": "pnpm install",
  "postAttachCommand": "bash .devcontainer/postAttachCommand.sh",

  "containerEnv": {
    "NODE_ENV": "development"
  },

  // pnpm store configuration
  // ⚠️ DO NOT use volume mounts for pnpm store (e.g., "source=genshin-pnpm-store,target=...")
  // Named Docker volumes mount as root, causing EACCES permission errors for the 'node' user.
  // Solution: Use default store location. First pnpm install is slower, but cache works normally after.

  "remoteUser": "node"
}
