{
  "name": "Genshin Team Builder",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers-extra/features/pre-commit:2": {},
    "ghcr.io/shinepukur/devcontainer-features/vale:1": {}
  },

  "customizations": {
    "vscode": {
      // MAINTENANCE: Keep this list in sync with .vscode/extensions.json
      "extensions": [
        // Language support
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // TypeScript enhancements
        "yoavbls.pretty-ts-errors",

        // Documentation
        "chrischinchilla.vale-vscode",

        // Developer experience
        "usernamehw.errorlens",
        "eamodio.gitlens",
        "streetsidesoftware.code-spell-checker",
        "meganrogge.template-string-converter",

        // Styling
        "bradlc.vscode-tailwindcss",

        // Testing (when Vitest is fully configured)
        "vitest.explorer",

        // API testing
        "rangav.vscode-thunder-client"
      ]
    }
  },

  "forwardPorts": [5173, 8080],
  "portsAttributes": {
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Backend (Hono)",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "npm install -g pnpm@9.15.4 && pnpm install && pre-commit install",
  "updateContentCommand": "pnpm install",
  "postAttachCommand": "echo '✅ Ready | Node $(node --version) | pnpm $(pnpm --version)'",

  "containerEnv": {
    "NODE_ENV": "development"
  },

  // pnpm store configuration
  // ⚠️ DO NOT use volume mounts for pnpm store (e.g., "source=genshin-pnpm-store,target=...")
  // Named Docker volumes mount as root, causing EACCES permission errors for 'node' user.
  // Solution: Use default store location. First pnpm install is slower, but cache works normally after.

  "remoteUser": "node"
}
