{
  "name": "@genshin/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.scripts.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "hono": "4.12.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.3.5",
    "eslint": "10.0.2",
    "globals": "17.4.0",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
