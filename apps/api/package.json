{
  "name": "@genshin/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "DEV=true tsx watch src/main.ts",
    "build": "tsc --project tsconfig.build.json && tsc-alias --project tsconfig.build.json && cp -r src/profiles dist/",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.scripts.json --noEmit"
  },
  "dependencies": {
    "@genshin/collection-json": "workspace:*",
    "@genshin/domain": "workspace:*",
    "@genshin/game-data": "workspace:*",
    "@hono/node-server": "2.0.4",
    "ajv": "8.20.0",
    "content-type": "2.0.0",
    "firebase-admin": "13.10.0",
    "google-gax": "5.0.6",
    "hono": "4.12.23",
    "negotiator": "1.0.0",
    "verzod": "0.5.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/negotiator": "0.6.4",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  }
}
